{
  "version": "0.1",
  "base_url": "https://data.okc.gov/services/portal/api",
  "city_bounds": {
    "name": "Oklahoma City public-data build extent",
    "bbox_lon_lat": [-97.85, 35.25, -97.15, 35.75]
  },
  "download_policy": {
    "commit_raw_downloads": false,
    "reason": "OKC public portal terms restrict redistribution or resale. Fetch during ingest and commit only scripts, source metadata, and derived schema."
  },
  "notes": [
    "Fetch public source data during ingest; do not commit downloaded OKC data without license review.",
    "The OKC portal records API returns tabular records. The map API returns full feature geometry in decimal degrees.",
    "OpenStreetMap data is ODbL and requires attribution and share-alike handling for derived databases."
  ],
